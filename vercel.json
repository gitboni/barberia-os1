{
  "rewrites": [
    { "source": "/sala/:shop", "destination": "/display.html" },
    { "source": "/admin/:shop", "destination": "/admin.html" },
    { "source": "/registro", "destination": "/register.html" },
    { "source": "/superadmin", "destination": "/superadmin.html" },
    { "source": "/privacidad", "destination": "/privacidad.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
